# App
APP_NAME="SME ERP Platform PH"
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
# IMPORTANT: the API must connect as a NON-superuser, NON-BYPASSRLS role so that
# Row-Level Security tenant isolation is actually enforced. Use a separate
# superuser connection only for running migrations.
DATABASE_URL="postgresql://sme_erp_app:sme_erp_password@localhost:5432/sme_erp_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_ACCESS_SECRET=replace_this_access_secret
JWT_REFRESH_SECRET=replace_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# Email (AgentMail — https://agentmail.to)
# When AGENTMAIL_API_KEY + AGENTMAIL_INBOX_ID are set, transactional email is
# sent via AgentMail; otherwise links are only logged (dev/test).
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=mymail@jlibao.cloud-ip.cc
MAIL_FROM=mymail@jlibao.cloud-ip.cc

# Security
# 32-byte key (base64) for field-level encryption of PII (TIN, SSS, salary).
PII_ENCRYPTION_KEY=
# Per-tenant rate limiting (requests per window).
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Subscription billing (Stripe is limited in PH — prefer a local gateway)
PAYMENT_PROVIDER=paymongo
PAYMENT_API_KEY=
