{
  "name": "sme-erp-platform-ph",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SME ERP platform for Philippine businesses with web, mobile, and backend applications.",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @sme-erp/api prisma:generate",
    "db:migrate": "pnpm --filter @sme-erp/api prisma:migrate",
    "db:studio": "pnpm --filter @sme-erp/api prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
